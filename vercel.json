{
  "builds": [
    {
      "src": "src/main/resources/static/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "src/main/resources/static/**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "src/main/resources/static/**/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/src/main/resources/static/index.html"
    },
    {
      "src": "/Shared/(.*)",
      "dest": "/src/main/resources/static/Shared/$1"
    },
    {
      "src": "/Councilor/(.*)/(.*)\\.(css|js|html)$",
      "dest": "/src/main/resources/static/Councilor/$1/$2.$3"
    },
    {
      "src": "/Councilor/(.*)\\.(css|js|html)$",
      "dest": "/src/main/resources/static/Councilor/$1.$2"
    },
    {
      "src": "/Admin/(.*)/(.*)\\.(css|js|html)$",
      "dest": "/src/main/resources/static/Admin/$1/$2.$3"
    },
    {
      "src": "/Admin/(.*)\\.(css|js|html)$",
      "dest": "/src/main/resources/static/Admin/$1.$2"
    },
    {
      "src": "/Councilor/Committee/committee-detail",
      "dest": "/src/main/resources/static/Councilor/Committee/committee-detail.html"
    },
    {
      "src": "/Councilor/(.*)",
      "dest": "/src/main/resources/static/Councilor/$1.html"
    },
    {
      "src": "/Admin/(.*)",
      "dest": "/src/main/resources/static/Admin/$1.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://sklinaw.onrender.com/api/$1",
      "headers": {
        "Access-Control-Allow-Credentials": "true"
      }
    },
    {
      "src": "/admin/(.*)",
      "dest": "https://sklinaw.onrender.com/admin/$1",
      "headers": {
        "Access-Control-Allow-Credentials": "true"
      }
    },
    {
      "src": "/(.*)\\.(css|js|png|jpg|svg|ico|json)$",
      "dest": "/src/main/resources/static/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/src/main/resources/static/$1.html"
    }
  ]
}