{
  "version": 2,
  "builds": [
    {
      "src": "src/main/resources/static/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/src/main/resources/static/index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://sklinaw.onrender.com/api/$1",
      "headers": {
        "Access-Control-Allow-Credentials": "true"
      }
    },
    {
      "src": "/admin/(.*)",
      "dest": "https://sklinaw.onrender.com/admin/$1",
      "headers": {
        "Access-Control-Allow-Credentials": "true"
      }
    },
    {
      "src": "/Shared/(.*)\\.(css|js)$",
      "dest": "/src/main/resources/static/Shared/$1.$2"
    },
    {
      "src": "/Councilor/([^/]+)/([^/]+)\\.(css|js)$",
      "dest": "/src/main/resources/static/Councilor/$1/$2.$3"
    },
    {
      "src": "/Admin/Approval/([^/]+)\\.(css|js)$",
      "dest": "/src/main/resources/static/Admin/Approval/$1.$2"
    },
    {
      "src": "/Public/([^/]+)/([^/]+)\\.(css|js)$",
      "dest": "/src/main/resources/static/Public/$1/$2.$3"
    },
    {
      "src": "/Councilor/([^/]+)/([^/]+)",
      "dest": "/src/main/resources/static/Councilor/$1/$2.html"
    },
    {
      "src": "/Admin/Approval/([^/]+)",
      "dest": "/src/main/resources/static/Admin/Approval/$1.html"
    },
    {
      "src": "/Public/([^/]+)/([^/]+)",
      "dest": "/src/main/resources/static/Public/$1/$2.html"
    },
    {
      "src": "/(.*)",
      "dest": "/src/main/resources/static/$1.html"
    }
  ]
}