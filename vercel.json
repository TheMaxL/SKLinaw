{
  "version": 2,
  "builds": [
    {
      "src": "src/main/resources/static/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/src/main/resources/static/index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://sklinaw.onrender.com/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "https://sklinaw.vercel.app",
        "Access-Control-Allow-Credentials": "true"
      }
    },
    {
      "src": "/admin/(.*)",
      "dest": "https://sklinaw.onrender.com/admin/$1",
      "headers": {
        "Access-Control-Allow-Origin": "https://sklinaw.vercel.app",
        "Access-Control-Allow-Credentials": "true"
      }
    },
    {
      "src": "/Shared/(.*)",
      "dest": "/src/main/resources/static/Shared/$1"
    },
    {
      "src": "/Councilor/(.*)/(.*)\\.(css|js)$",
      "dest": "/src/main/resources/static/Councilor/$1/$2.$3"
    },
    {
      "src": "/Councilor/Home/home",
      "dest": "/src/main/resources/static/Councilor/Home/home.html"
    },
    {
      "src": "/Councilor/Dashboard/dashboard",
      "dest": "/src/main/resources/static/Councilor/Dashboard/dashboard.html"
    },
    {
      "src": "/Admin/Admin",
      "dest": "/src/main/resources/static/Admin/Admin.html"
    },
    {
      "src": "/Councilor/(.*)/(.*)\\.html",
      "dest": "/src/main/resources/static/Councilor/$1/$2.html"
    },
    {
      "src": "/Admin/(.*)\\.html",
      "dest": "/src/main/resources/static/Admin/$1.html"
    },
    {
      "src": "/(.*)\\.(css|js|png|jpg|svg|ico|json)$",
      "dest": "/src/main/resources/static/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/src/main/resources/static/$1.html"
    }
  ]
}