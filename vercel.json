{
  "builds": [
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://sklinaw.onrender.com/api/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "https://sklinaw.onrender.com/admin/$1"
    },
    {
      "src": "/(.*)-detail",
      "dest": "/static/$1-detail.html"
    },
    {
      "src": "/(.*)",
      "dest": "/static/$1.html"
    }
  ]
}