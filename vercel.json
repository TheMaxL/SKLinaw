{
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://sklinaw.onrender.com/api/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "https://sklinaw.onrender.com/admin/$1"
    },
    {
      "src": "/(.*)-detail",
      "dest": "/$1-detail.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1.html"
    }
  ]
}